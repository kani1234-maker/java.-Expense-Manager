//Expense class
class Expense {
    int userId;
    String userName;
    String userEmail;
    String userPhone;
    int userPassword;
    int balance;
    int amountSpent;
    String date;
    int totalExpense;
    int remainingBalance;

    Expense(int userId, String userName, String userEmail, String userPhone,int userPassword, int balance, int amountSpent, String date,int totalExpense, int remainingBalance) {

        this.userId = userId;
        this.userName = userName;
        this.userEmail = userEmail;
        this.userPhone = userPhone;
        this.userPassword = userPassword;
        this.balance = balance;
        this.amountSpent = amountSpent;
        this.date = date;
        this.totalExpense = totalExpense;
        this.remainingBalance = remainingBalance;
    }

    void displayExpenseDetails() {
        System.out.println("\n--- Expense Details ---");
        System.out.println("User ID: " + userId);
        System.out.println("User Name: " + userName);
        System.out.println("Email: " + userEmail);
        System.out.println("Phone: " + userPhone);
        System.out.println("Balance: " + balance);
        System.out.println("Amount Spent: " + amountSpent);
        System.out.println("Date: " + date);
        System.out.println("Total Expense: " + totalExpense);
        System.out.println("Remaining Balance: " + remainingBalance);
    }
}
//ExpenseManager class
import java.util.ArrayList;
import java.util.Scanner;

public class ExpenseManager {

    static ArrayList<Expense> expenses = new ArrayList<>();

    public static void addExpense(Scanner sc) {

        System.out.print("Enter User ID: ");
        int userId = sc.nextInt();
        sc.nextLine();

        System.out.print("Enter Name: ");
        String name = sc.nextLine();

        System.out.print("Enter Email: ");
        String email = sc.nextLine();

        System.out.print("Enter Phone: ");
        String phone = sc.nextLine();

        System.out.print("Enter Password: ");
        int password = sc.nextInt();

        System.out.print("Enter Balance: ");
        int balance = sc.nextInt();

        System.out.print("Enter Amount Spent: ");
        int amountSpent = sc.nextInt();
        sc.nextLine();

        System.out.print("Enter Date: ");
        String date = sc.nextLine();

        int totalExpense = amountSpent; 
        int remainingBalance = balance - amountSpent;

        Expense exp = new Expense(userId, name, email, phone, password,balance, amountSpent, date, totalExpense, remainingBalance);

        expenses.add(exp);

        System.out.println("Expense Added Successfully!");
    }

    public static void viewExpenses() {
        if (expenses.isEmpty()) {
            System.out.println("No records found!");
            return;
        }

        for (Expense e : expenses) {
            e.displayExpenseDetails();
        }
    }
    public static void searchUserById(Scanner sc) {

    System.out.print("Enter User ID to search: ");
    int id = sc.nextInt();

    boolean found = false;

    for (Expense e : expenses) {
        if (e.userId == id) {
            e.displayExpenseDetails();
            found = true;
            break;
        }
    }

    if (!found) {
        System.out.println("User not found!");
    }
}

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);
        int choice;

        do {
            System.out.println("\n===== Expense Manager =====");
            System.out.println("1. Add Expense");
            System.out.println("2. View Expenses");
            System.out.println("3. Search user by ID");
            System.out.println("4. Exit");
            System.out.print("Enter choice: ");

            choice = sc.nextInt();

            switch (choice) {
                case 1:
                    addExpense(sc);
                    break;

                case 2:
                    viewExpenses();
                    break;

                case 3:
                    searchUserById(sc);
                    break;

                case 4:
                    System.out.println("Exiting...");
                    break;

                default:
                    System.out.println("Invalid choice!");
            }

        } while (choice != 4);

        sc.close();
    }
}
